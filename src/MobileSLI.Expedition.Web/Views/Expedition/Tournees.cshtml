@model TourneesIndexViewModel
@{
    ViewData["Title"] = "Tournées préparables";

    static bool IsReadyForLockStatus(string? status)
    {
        var normalized = status?.Trim().ToUpperInvariant();
        return normalized is "PRET_VERROUILLAGE" or "PRETE_VERROUILLAGE";
    }

    static bool IsInPreparationStatus(string? status)
    {
        var normalized = status?.Trim().ToUpperInvariant();
        return normalized is "EN_PREPARATION_WEB" or "BROUILLON";
    }

    var lockedCount = Model.Tournees.Count(t => t.IsLocked);
    var readyCount = Model.Tournees.Count(t => !t.IsLocked && IsReadyForLockStatus(t.EtatPreparation));
    var inProgressCount = Model.Tournees.Count(t => !t.IsLocked && IsInPreparationStatus(t.EtatPreparation));
}

<section class="screen-header">
    <div>
        <p class="eyebrow">Date préparée</p>
        <h1>Tournées préparables</h1>
        <p class="lead">Date tournée : @Model.DateTournee.ToString("dd/MM/yyyy") · Fuseau métier : @Model.FuseauHoraireMetier</p>
    </div>
    <a class="button button-secondary" asp-controller="Expedition" asp-action="Index">Retour accueil</a>
</section>

<section class="metrics-row">
    <article class="metric-card">
        <span>Tournées</span>
        <strong>@Model.Tournees.Count</strong>
    </article>
    <article class="metric-card">
        <span>En préparation</span>
        <strong>@inProgressCount</strong>
    </article>
    <article class="metric-card">
        <span>Prêtes</span>
        <strong>@readyCount</strong>
    </article>
    <article class="metric-card">
        <span>Verrouillées</span>
        <strong>@lockedCount</strong>
    </article>
</section>

@if (Model.Tournees.Count == 0)
{
    <section class="panel">
        <p>Aucune tournée disponible pour cette date.</p>
    </section>
}
else
{
    <section class="tournee-board">
        <div class="panel">
            <div class="section-header compact">
                <h2>Liste des tournées</h2>
                <span class="badge badge-soft">@Model.Tournees.Count tournée(s)</span>
            </div>

            <div class="tournee-list compact-list">
                @foreach (var tournee in Model.Tournees)
                {
                    <article class="tournee-item">
                        <div>
                            <div class="tournee-title">@tournee.CodeTournee</div>
                            <p>@tournee.LibelleTournee</p>
                            <span class="badge @CssStatus.ClassFor(tournee.EtatPreparation)">@tournee.EtatPreparation</span>
                        </div>
                        <div class="tournee-actions">
                            <span class="line-count">@tournee.NombreLignes ligne(s)</span>
                            <a class="button button-primary button-small" asp-controller="Expedition" asp-action="Preparer" asp-route-codeTournee="@tournee.CodeTournee">
                                @(tournee.IsLocked ? "Consulter" : "Préparer")
                            </a>
                            <a class="button button-secondary button-small" asp-controller="Expedition" asp-action="Recapitulatif" asp-route-codeTournee="@tournee.CodeTournee">Récap</a>
                        </div>
                    </article>
                }
            </div>
        </div>

        <aside class="panel side-panel">
            <p class="eyebrow">Articles suivis</p>
            <h2>Livré prévu</h2>
            <div class="article-stack">
                <span>ROLLS</span>
                <span>TAPIS</span>
                <span>SACS</span>
            </div>
        </aside>
    </section>
}
