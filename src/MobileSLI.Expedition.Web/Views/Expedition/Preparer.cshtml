@model PreparationTourneeViewModel
@{
    ViewData["Title"] = "Préparer une tournée";
}

<section class="screen-header">
    <div>
        <p class="eyebrow">Préparation côté web</p>
        <h1>@Model.CodeTournee - @Model.LibelleTournee</h1>
        <p class="lead">
            Date tournée : @Model.DateTournee.ToString("dd/MM/yyyy") · état :
            <span class="badge @CssStatus.ClassFor(Model.EtatPreparation)">@Model.EtatPreparation</span>
        </p>
    </div>
    <div class="actions">
        <a class="button button-secondary" asp-action="Tournees">Liste des tournées</a>
        <a class="button button-secondary" asp-action="Recapitulatif" asp-route-codeTournee="@Model.CodeTournee">Récapitulatif</a>
    </div>
</section>

<section class="metrics-row">
    <article class="metric-card">
        <span>Lignes</span>
        <strong>@Model.NombreLignes</strong>
    </article>
    <article class="metric-card">
        <span>Modifiées</span>
        <strong>@Model.NombreLignesModifiees</strong>
    </article>
    <article class="metric-card">
        <span>Commentaires</span>
        <strong>@Model.NombreCommentaires</strong>
    </article>
    <article class="metric-card">
        <span>Fermetures</span>
        <strong>@Model.NombreFermeturesSignalees</strong>
    </article>
</section>

@if (!ViewData.ModelState.IsValid)
{
    <section class="alert alert-error">
        <strong>Correction nécessaire</strong>
        <div asp-validation-summary="All"></div>
    </section>
}

@if (Model.IsReadOnly)
{
    <div class="alert alert-info">Cette tournée est verrouillée en BD. La consultation reste possible, mais les champs sont en lecture seule.</div>
}

<form asp-action="Preparer" 
      asp-route-codeTournee="@Model.CodeTournee" 
      method="post" 
      data-loading-form>
    @Html.AntiForgeryToken()

    <section class="panel panel-table">
        <div class="section-header compact">
            <h2>Lignes de tournée</h2>
            <span class="badge badge-soft">Saisie locale · pas de POST API central</span>
        </div>

        <div class="table-wrapper">
            <table class="data-table preparation-table">
                <thead>
                    <tr>
                        <th>Client / PDL</th>
                        <th>Adresse</th>
                        @foreach (var article in Model.Articles)
                        {
                            <th class="quantity-heading">@article.LibelleArticle</th>
                        }
                        <th>Commentaire exceptionnel</th>
                        <th>État</th>
                        <th>Détail</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Lignes.Count; i++)
                    {
                        var ligne = Model.Lignes[i];
                        <tr class="@(ligne.EstModifiee ? "row-modified" : string.Empty)">
                            <td class="client-cell">
                                <input type="hidden" name="Lignes[@i].IdLigneSource" value="@ligne.IdLigneSource" />
                                <strong>@ligne.NomClient</strong>
                                <span>Client @ligne.NumClient · PDL @ligne.CodePDL</span>
                                <small>Arrêt @ligne.OrdreArret · @ligne.DescriptionPDL</small>
                            </td>
                            <td class="address-cell">@ligne.Adresse</td>
                            @for (var j = 0; j < Model.Articles.Count; j++)
                            {
                                var article = Model.Articles[j];
                                var value = ligne.Quantites.TryGetValue(article.CodeArticle, out var quantite) ? quantite : null;
                                <td class="quantity-cell">
                                    <input type="hidden" name="Lignes[@i].Quantites[@j].CodeArticle" value="@article.CodeArticle" />
                                    <input
                                        type="number"
                                        min="0"
                                        step="1"
                                        name="Lignes[@i].Quantites[@j].QuantiteLivreePrevue"
                                        value="@(value.HasValue ? value.Value.ToString() : string.Empty)"
                                        placeholder="—"
                                        data-line-id="@ligne.IdLigneSource"
                                        data-article-code="@article.CodeArticle"
                                        data-code-tournee="@Model.CodeTournee"
                                        onchange="updateQuantitePrevue(this)"
                                        @(Model.IsReadOnly ? "readonly" : string.Empty) />
                                </td>
                            }
                            <td class="comment-cell">
                                <textarea name="Lignes[@i].CommentaireExceptionnel" rows="1" placeholder="Commentaire" @(Model.IsReadOnly ? "readonly" : string.Empty)>@ligne.CommentaireExceptionnel</textarea>
                            </td>
                            <td>
                                @if (ligne.FermetureClient)
                                {
                                    <span class="badge badge-warning">Fermeture</span>
                                }
                                else if (ligne.EstModifiee)
                                {
                                    <span class="badge badge-info">Modifiée</span>
                                }
                                else
                                {
                                    <span class="badge badge-neutral">Non préparée</span>
                                }
                            </td>
                            <td>
                                <a class="button button-secondary button-small"
                                   asp-action="DetailLigne"
                                   asp-route-codeTournee="@Model.CodeTournee"
                                   asp-route-idLigneSource="@ligne.IdLigneSource">Ouvrir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (!Model.IsReadOnly)
    {
        <section class="sticky-actions">
            <button class="button button-primary" type="submit" name="ActionType" value="recap">Enregistrer et voir le récapitulatif</button>
        </section>
    }
</form>

