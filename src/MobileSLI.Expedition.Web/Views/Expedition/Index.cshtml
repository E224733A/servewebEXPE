@model HomeIndexViewModel
@{
    ViewData["Title"] = "Accueil";
}

<section class="hero">
    <div>
        <p class="eyebrow">Module backend / web Expédition</p>
        <h1>Préparation des tournées</h1>
        <p class="lead">
            Charge les données de la prochaine date préparable calculée par l'API centrale,
            puis prépare les quantités livrées prévues et les commentaires exceptionnels côté web.
        </p>
    </div>

    <form asp-action="Charger" method="post" class="hero-action">
        @Html.AntiForgeryToken()
        <button type="submit" class="button button-primary">Charger les données à préparer</button>
        <span class="helper">Aucun choix manuel de date.</span>
    </form>
</section>

<section class="grid two">
    <article class="card">
        <h2>Dernier chargement</h2>
        @if (Model.HasLoadedData)
        {
            <dl class="summary-list">
                <dt>Date préparée</dt>
                <dd>@Model.DateTournee?.ToString("dd/MM/yyyy")</dd>
                <dt>Tournées chargées</dt>
                <dd>@Model.TourneesCount</dd>
            </dl>
            <a class="button button-secondary" asp-action="Tournees">Ouvrir les tournées</a>
        }
        else
        {
            <p>Aucune donnée n'a encore été chargée côté application web.</p>
        }
    </article>

    <article class="card">
        <h2>Rappel métier</h2>
        <ul class="clean-list">
            <li>Les modifications sont enregistrées en brouillon SQLite.</li>
            <li>Aucun POST API central n'est fait à chaque modification.</li>
            <li>Le verrouillage automatique envoie le lot complet à l'API autour de 00:05.</li>
            <li>Les rolls vides récupérés ne sont pas saisis ici.</li>
        </ul>
    </article>
</section>

<section class="card">
    <h2>Dernières tentatives de verrouillage</h2>
    @if (Model.RecentLocks.Count == 0)
    {
        <p>Aucune tentative de verrouillage enregistrée.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Lot</th>
                        <th>Date tournée</th>
                        <th>Statut</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentLocks)
                    {
                        <tr>
                            <td>@item.IdLotVerrouillage</td>
                            <td>@item.DateTournee.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge">@item.Status</span></td>
                            <td>@item.ApiMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
