@model HomeIndexViewModel
@{
    ViewData["Title"] = "Accueil";
}

<section class="screen-grid screen-grid-home">
    <article class="panel panel-hero">
        <p class="eyebrow">Module Expédition</p>
        <h1>Préparer les données de tournée</h1>
        <p class="lead">
            Chargement des tournées à préparer, saisie des quantités prévues, puis verrouillage automatique.
        </p>

        <div class="hero-actions-row">
            <form asp-action="Charger" method="post" data-loading-form>
                @Html.AntiForgeryToken()
                <button type="submit" class="button button-primary">Charger les données à préparer</button>
            </form>

            <form asp-action="TesterApi" method="post" data-loading-form>
                @Html.AntiForgeryToken()
                <button type="submit" class="button button-test">Mode test API</button>
            </form>
        </div>

        <div class="status-strip status-strip-info">
            <strong>Règle métier</strong>
            <span>Aucun choix manuel de date. La date est calculée automatiquement.</span>
        </div>
        <div class="status-strip status-strip-warning">
            <strong>Attention</strong>
            <span>Le verrouillage automatique reste prévu autour de 00:05.</span>
        </div>
    </article>

    <aside class="panel side-panel">
        <p class="eyebrow">Dernier chargement</p>
        @if (Model.HasLoadedData)
        {
            <div class="metric-stack">
                <div class="metric-card">
                    <span>Date préparée</span>
                    <strong>@Model.DateTournee?.ToString("dd/MM/yyyy")</strong>
                </div>
                <div class="metric-card">
                    <span>Tournées chargées</span>
                    <strong>@Model.TourneesCount</strong>
                </div>
            </div>
            <a class="button button-secondary full-width" asp-action="Tournees">Ouvrir les tournées</a>
        }
        else
        {
            <p class="muted">Aucune donnée n'a encore été chargée.</p>
        }
    </aside>
</section>

<section class="panel">
    <div class="section-header">
        <div>
            <p class="eyebrow">Verrouillage</p>
            <h2>Dernières tentatives</h2>
        </div>
        <span class="badge badge-soft">Automatique</span>
    </div>

    @if (Model.RecentLocks.Count == 0)
    {
        <p class="muted">Aucune tentative de verrouillage enregistrée.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Lot</th>
                        <th>Date tournée</th>
                        <th>Statut</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentLocks)
                    {
                        <tr>
                            <td>@item.IdLotVerrouillage</td>
                            <td>@item.DateTournee.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge @CssStatus.ClassFor(item.Status)">@item.Status</span></td>
                            <td>@item.ApiMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>