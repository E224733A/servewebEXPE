@model PreparationTourneeViewModel
@{
    ViewData["Title"] = "Expédition - Détail ligne";
    var selectedLineId = ViewData["SelectedLineId"] as string;
    var ligne = Model.Lignes.First(l => string.Equals(l.IdLigneSource, selectedLineId, StringComparison.OrdinalIgnoreCase));
    static bool IsReadyForLockStatus(string? status)
    {
        var normalized = status?.Trim().ToUpperInvariant();
        return normalized is "PRET_VERROUILLAGE" or "PRETE_VERROUILLAGE";
    }

    var isReadyForLock = IsReadyForLockStatus(Model.EtatPreparation);
}

<section class="screen-header">
    <div>
        <p class="eyebrow">Expédition · détail quantité</p>
        <h1>@ligne.NomClient</h1>
        <p class="lead">Tournée @Model.CodeTournee · arrêt @ligne.OrdreArret · PDL @ligne.CodePDL</p>
    </div>
    <div class="actions">
        <a class="button button-secondary" asp-action="Preparer" asp-route-codeTournee="@Model.CodeTournee">Retour préparation</a>
        <a class="button button-secondary" asp-action="Recapitulatif" asp-route-codeTournee="@Model.CodeTournee">Récapitulatif quantités</a>
    </div>
</section>

@if (!ViewData.ModelState.IsValid)
{
    <section class="alert alert-error">
        <strong>Correction nécessaire</strong>
        <div asp-validation-summary="All"></div>
    </section>
}

@if (Model.IsReadOnly)
{
    <div class="alert alert-info">Cette tournée est verrouillée. La consultation reste possible, mais les champs sont en lecture seule.</div>
}
else if (isReadyForLock)
{
    <div class="alert alert-info">
        Cette tournée est prête pour verrouillage. Une correction sur cette ligne conserve l'état prêt pour verrouillage.
    </div>
}

<form asp-action="DetailLigne" asp-route-codeTournee="@Model.CodeTournee" asp-route-idLigneSource="@ligne.IdLigneSource" method="post" class="detail-edit-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="IdLigneSource" value="@ligne.IdLigneSource" />

    <section class="detail-layout">
        <article class="panel detail-main-card">
            <div class="section-header compact">
                <h2>Informations client</h2>
                <span class="badge @CssStatus.ClassFor(Model.EtatPreparation)">@Model.EtatPreparation</span>
            </div>

            <div class="detail-grid">
                <div class="detail-field"><span>Client</span><strong>@ligne.NomClient</strong><small>@ligne.NumClient</small></div>
                <div class="detail-field"><span>Point de livraison</span><strong>@ligne.CodePDL</strong><small>@ligne.DescriptionPDL</small></div>
                <div class="detail-field full-row"><span>Adresse</span><strong>@ligne.Adresse</strong></div>
                <div class="detail-field full-row detail-field-info"><span>Instructions existantes</span><strong>@(string.IsNullOrWhiteSpace(ligne.Instructions) ? "Aucune instruction." : ligne.Instructions)</strong></div>
                <div class="detail-field"><span>Zone de déchargement</span><strong>@(string.IsNullOrWhiteSpace(ligne.ZoneDechargement) ? "Non renseignée" : ligne.ZoneDechargement)</strong></div>
                <div class="detail-field"><span>Dernière modification quantité</span><strong>@(ligne.DerniereModificationUtc.HasValue ? ligne.DerniereModificationUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "Non modifiée")</strong></div>
            </div>

            <div class="status-strip status-strip-warning">
                <strong>Séparation métier</strong>
                <span>Les commentaires exceptionnels sont saisis uniquement depuis l'interface Administration.</span>
            </div>

            <details class="technical-details">
                <summary>Identifiant technique</summary>
                <code>@ligne.IdLigneSource</code>
            </details>
        </article>

        <aside class="panel detail-side-card">
            <p class="eyebrow">Quantités livrées prévues</p>

            <div class="quantity-edit-list">
                @for (var j = 0; j < Model.Articles.Count; j++)
                {
                    var article = Model.Articles[j];
                    var value = ligne.Quantites.TryGetValue(article.CodeArticle, out var quantite) ? quantite : null;
                    <div class="quantity-edit-item">
                        <input type="hidden" name="Quantites[@j].CodeArticle" value="@article.CodeArticle" />
                        <div>
                            <label for="detail-quantite-@j">@article.CodeArticle</label>
                            <small>@article.LibelleArticle</small>
                        </div>

                        @if (Model.IsReadOnly)
                        {
                            <strong>@(value.HasValue ? value.Value.ToString() : "—")</strong>
                        }
                        else
                        {
                            <div class="quantity-input-with-marker">
                                <input id="detail-quantite-@j"
                                       type="number"
                                       min="0"
                                       step="1"
                                       name="Quantites[@j].QuantiteLivreePrevue"
                                       value="@(value.HasValue ? value.Value.ToString() : string.Empty)"
                                       placeholder="—" />
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="status-strip status-strip-warning">
                <strong>Règle importante</strong>
                <span>Vide = non renseigné</span>
                <span>0 = zéro explicite</span>
            </div>

            @if (!Model.IsReadOnly)
            {
                <div class="detail-form-actions">
                    <a class="button button-secondary" asp-action="Preparer" asp-route-codeTournee="@Model.CodeTournee">Retour</a>
                    <button class="button button-final" type="submit">@(isReadyForLock ? "Mettre à jour verrouillage" : "Valider ligne")</button>
                </div>
            }
        </aside>
    </section>
</form>

<style>
    .detail-edit-form { display: block; }
    .detail-field-info { background: var(--surface-blue); border-color: #bfdbfe; }
    .quantity-edit-list { display: grid; gap: 14px; margin: 14px 0 18px; }
    .quantity-edit-item { display: grid; grid-template-columns: minmax(0, 1fr) 92px; align-items: center; gap: 12px; padding: 14px; border: 1px solid var(--border); border-radius: 18px; background: var(--surface-soft); }
    .quantity-edit-item label, .quantity-edit-item small { display: block; }
    .quantity-edit-item label { font-size: 16px; font-weight: 900; color: var(--text); }
    .quantity-edit-item small { margin-top: 4px; color: var(--muted); font-weight: 700; }
    .quantity-edit-item strong { display: inline-flex; justify-content: center; align-items: center; min-height: 42px; border-radius: 12px; background: #eef2f7; font-size: 18px; }
    .quantity-input-with-marker input { text-align: center; font-weight: 900; }
    .detail-form-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 18px; }
    .detail-form-actions .button { width: 100%; }
    @@media (max-width: 760px) { .quantity-edit-item { grid-template-columns: 1fr; } .detail-form-actions { grid-template-columns: 1fr; } }
</style>
