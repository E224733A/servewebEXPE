@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@model PreparationTourneeViewModel
@{
    ViewData["Title"] = "Récapitulatif";
    var isDevelopment = string.Equals(Env.EnvironmentName, "Development", StringComparison.OrdinalIgnoreCase);
    var isReadyForLock = string.Equals(Model.EtatPreparation, "PRETE_VERROUILLAGE", StringComparison.OrdinalIgnoreCase);
}

<section class="screen-header">
    <div>
        <p class="eyebrow">Récapitulatif avant verrouillage automatique</p>
        <h1>@Model.CodeTournee - @Model.LibelleTournee</h1>
        <p class="lead">
            Date tournée : @Model.DateTournee.ToString("dd/MM/yyyy") · état :
            <span class="badge @CssStatus.ClassFor(Model.EtatPreparation)">@Model.EtatPreparation</span>
        </p>
    </div>
    <div class="actions">
        <a class="button button-secondary" asp-action="Preparer" asp-route-codeTournee="@Model.CodeTournee">Retour préparation</a>
        <a class="button button-secondary" asp-action="Tournees">Liste des tournées</a>
    </div>
</section>

<section class="metrics-row">
    <article class="metric-card">
        <span>Lignes</span>
        <strong>@Model.NombreLignes</strong>
    </article>
    <article class="metric-card">
        <span>Quantités renseignées</span>
        <strong>@Model.NombreQuantitesRenseignees</strong>
    </article>
    <article class="metric-card">
        <span>Commentaires</span>
        <strong>@Model.NombreCommentaires</strong>
    </article>
    <article class="metric-card metric-card-warning">
        <span>Verrouillage prévu</span>
        <strong>00:05</strong>
    </article>
</section>

@if (isDevelopment)
{
    <section class="panel">
        <div class="section-header">
            <div>
                <p class="eyebrow">Développement uniquement</p>
                <h2>Verrouillage manuel de test</h2>
            </div>
            <span class="badge badge-warning">DEV</span>
        </div>

        <div class="status-strip status-strip-warning">
            <strong>Attention</strong>
            <span>
                Ce bouton déclenche le même service que le verrouillage automatique de 00:05.
                Il sert uniquement à tester le POST API de verrouillage et la sauvegarde SQL Server.
            </span>
        </div>

        @if (isReadyForLock && !Model.IsReadOnly)
        {
            <form asp-action="VerrouillerManuellementDeveloppement"
                  method="post"
                  data-loading-form>
                @Html.AntiForgeryToken()
                <input type="hidden" name="codeTournee" value="@Model.CodeTournee" />

                <button type="submit" class="button button-final">
                    Verrouiller maintenant en développement
                </button>
            </form>
        }
        else
        {
            <div class="status-strip status-strip-info">
                <strong>Bouton indisponible</strong>
                <span>
                    La tournée doit être marquée PRETE_VERROUILLAGE et ne doit pas déjà être verrouillée.
                </span>
            </div>
        }
    </section>
}

<section class="panel panel-table">
    <div class="section-header">
        <div>
            <p class="eyebrow">Contrôle final</p>
            <h2>Valeurs qui seront transmises au verrouillage</h2>
        </div>
        <span class="badge badge-soft">Mobile alimenté uniquement après verrouillage BD</span>
    </div>

    <div class="status-strip status-strip-info">
        <strong>Important</strong>
        <span>Le mobile ne lit pas ce brouillon. Les données seront disponibles uniquement après sauvegarde et verrouillage en SQL Server par l'API centrale.</span>
    </div>

    <div class="table-wrapper">
        <table class="data-table recap-table">
            <thead>
                <tr>
                    <th>Ordre</th>
                    <th>Client</th>
                    <th>PDL</th>
                    @foreach (var article in Model.Articles)
                    {
                        <th>@article.LibelleArticle</th>
                    }
                    <th>Commentaire exceptionnel</th>
                    <th>Instructions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ligne in Model.Lignes)
                {
                    <tr>
                        <td>@ligne.OrdreArret</td>
                        <td>@ligne.NomClient</td>
                        <td>@ligne.CodePDL</td>
                        @foreach (var article in Model.Articles)
                        {
                            var value = ligne.Quantites.TryGetValue(article.CodeArticle, out var quantite) ? quantite : null;
                            <td>@(value.HasValue ? value.Value.ToString() : "Non renseigné")</td>
                        }
                        <td class="long-text">@(string.IsNullOrWhiteSpace(ligne.CommentaireExceptionnel) ? "" : ligne.CommentaireExceptionnel)</td>
                        <td class="long-text">@(string.IsNullOrWhiteSpace(ligne.Instructions) ? "" : ligne.Instructions)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
