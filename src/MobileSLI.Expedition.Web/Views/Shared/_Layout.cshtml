<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expédition MobileSLI</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <a class="brand" asp-controller="Expedition" asp-action="Index">MobileSLI Expédition</a>
        <nav class="nav">
            <a asp-controller="Expedition" asp-action="Index">Accueil</a>
            <a asp-controller="Expedition" asp-action="Tournees">Tournées</a>
        </nav>
    </header>

    <main class="page">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-error">@error</div>
        }

        @RenderBody()
    </main>

    <footer class="footer">
        Module Expédition - brouillons locaux SQLite - verrouillage automatique API
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
