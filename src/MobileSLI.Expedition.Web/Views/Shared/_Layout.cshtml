<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expédition MobileSLI</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="global-loading-overlay" class="loading-overlay d-none" aria-live="polite" aria-busy="true">
        <div class="loading-card">
            <strong>Chargement en cours</strong>
            <p>Merci de patienter.</p>
        </div>
    </div>

    <div class="app-shell">
        <aside class="sidebar">
            <a class="sidebar-brand" asp-controller="Expedition" asp-action="Index">
                <span class="brand-icon">SLI</span>
                <span>
                    <strong>MobileSLI</strong>
                    <small>Expédition</small>
                </span>
            </a>

            <nav class="sidebar-nav" aria-label="Navigation principale">
                <a class="sidebar-link" asp-controller="Expedition" asp-action="Index">
                    <span class="sidebar-dot"></span>
                    Accueil
                </a>
                <a class="sidebar-link" asp-controller="Expedition" asp-action="Tournees">
                    <span class="sidebar-dot"></span>
                    Tournées
                </a>
                <a class="sidebar-link" asp-controller="Expedition" asp-action="Tournees">
                    <span class="sidebar-dot"></span>
                    Préparation
                </a>
                <a class="sidebar-link" asp-controller="Expedition" asp-action="Tournees">
                    <span class="sidebar-dot"></span>
                    Récapitulatif
                </a>
            </nav>

            <div class="sidebar-note">
                <strong>00:05</strong>
                <span>Verrouillage automatique</span>
            </div>
        </aside>

        <main class="app-main">
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success">@success</div>
            }

            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-error">@error</div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
