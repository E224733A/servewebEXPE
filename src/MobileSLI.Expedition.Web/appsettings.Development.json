{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MobileSLI.Expedition": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ExpeditionApi": {
    "UseFakeApi": false,
    "BaseUrl": "http://localhost:5000/",
    "TimeoutSeconds": 30,
    "RequireHttps": false,
    "ApiKeyHeaderName": "X-Expedition-Api-Key",
    "ApiKey": ""
  },
  "Verrouillage": {
    "Enabled": true,
    "TimeZoneId": "Europe/Paris",
    "Hour": 0,
    "Minute": 5,
    "WindowMinutes": 20,
    "CheckEverySeconds": 30,
    "LotSequence": "001"
  },
  "AccessControl": {
    "Enabled": true,
    "RequireHttps": false,
    "BlockMobileUserAgents": false,
    "RequireIpAllowListInProduction": false,
    "AllowedIpPrefixes": []
  }
}
