{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MobileSLI.Expedition": "Debug"
    }
  },
  "ExpeditionApi": {
    "UseFakeApi": true,
    "BaseUrl": "http://localhost:5000/",
    "TimeoutSeconds": 30
  },
  "Verrouillage": {
    "Enabled": true,
    "TimeZoneId": "Europe/Paris",
    "Hour": 0,
    "Minute": 5,
    "WindowMinutes": 20,
    "CheckEverySeconds": 30,
    "LotSequence": "001"
  }
}
