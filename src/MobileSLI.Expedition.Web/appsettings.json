{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ExpeditionApi": {
    "UseFakeApi": true,
    "BaseUrl": "http://localhost:5000/",
    "TimeoutSeconds": 30
  },
  "ExpeditionDb": {
    "DatabasePath": "data/expedition-drafts.sqlite3"
  },
  "Verrouillage": {
    "Enabled": true,
    "TimeZoneId": "Europe/Paris",
    "Hour": 0,
    "Minute": 5,
    "WindowMinutes": 20,
    "CheckEverySeconds": 60,
    "LotSequence": "001"
  }
}
