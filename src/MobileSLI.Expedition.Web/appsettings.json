{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;[::1];SERVWEB;192.168.1.232",
  "ExpeditionApi": {
    "UseFakeApi": false,
    "BaseUrl": "http://192.168.1.233:5000/",
    "TimeoutSeconds": 90,
    "RequireHttps": false,
    "ApiKeyHeaderName": "X-Expedition-Api-Key",
    "ApiKey": ""
  },
  "ExpeditionDb": {
    "DatabasePath": "data/expedition-drafts.sqlite3"
  },
  "Verrouillage": {
    "Enabled": true,
    "TimeZoneId": "Europe/Paris",
    "Hour": 22,
    "Minute": 35,
    "WindowMinutes": 20,
    "CheckEverySeconds": 60,
    "LotSequence": "001",
    "LockSecretHeaderName": "X-SERVEXPE-LOCK-SECRET",
    "LockSecret": ""
  },
  "AccessControl": {
    "Enabled": true,
    "RequireHttps": false,
    "BlockMobileUserAgents": true,
    "RequireIpAllowListInProduction": false,
    "AllowedIpPrefixes": []
  }
}
